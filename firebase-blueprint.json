{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "college": { "type": "string" },
        "semester": { "type": "string" },
        "email": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "streak": { "type": "number" },
        "lastStudyDate": { "type": "string", "format": "date-time" },
        "totalStudyTime": { "type": "number" }
      },
      "required": ["name", "email"]
    },
    "Material": {
      "title": "Study Material",
      "description": "Uploaded documents and images.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "docx", "image"] },
        "url": { "type": "string" },
        "subjectId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array" },
        "summary": { "type": "string" }
      },
      "required": ["title", "type", "url", "userId"]
    },
    "StudyPlan": {
      "title": "Study Plan",
      "description": "Automated schedule for exam preparation.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "examDate": { "type": "string", "format": "date-time" },
        "targetContent": { "type": "string" },
        "dailyAvailability": { "type": "number" },
        "schedule": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "examDate"]
    },
    "Simulation": {
      "title": "Simulation Session",
      "description": "Timed simulation for questions.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subjectId": { "type": "string" },
        "count": { "type": "number" },
        "timeLimit": { "type": "number" },
        "questionIds": { "type": "array" },
        "userAnswers": { "type": "object" },
        "score": { "type": "number" },
        "correctCount": { "type": "number" },
        "duration": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "questionIds"]
    },
    "GlobalTag": {
      "title": "Global Tag",
      "description": "Custom tags for organizing content.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["userId", "name"]
    },
    "PerformanceMetric": {
      "title": "Performance Metric",
      "description": "Tracking user performance over time.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subjectId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "accuracy": { "type": "number" },
        "questionsAnswered": { "type": "number" },
        "timeSpent": { "type": "number" }
      }
    },
    "Subject": {
      "title": "Study Subject",
      "description": "Represents a medical discipline (e.g., Anatomy).",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "color": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["name", "userId"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "Represents a single flashcard for spaced repetition.",
      "type": "object",
      "properties": {
        "front": { "type": "string" },
        "back": { "type": "string" },
        "subjectId": { "type": "string" },
        "userId": { "type": "string" },
        "nextReview": { "type": "string", "format": "date-time" },
        "interval": { "type": "number" },
        "easiness": { "type": "number" },
        "repetitions": { "type": "number" },
        "tags": { "type": "array" }
      },
      "required": ["front", "back", "userId", "subjectId"]
    },
    "Note": {
      "title": "Study Note",
      "description": "Rich text notes organized by subject.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "subjectId": { "type": "string" },
        "userId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "tags": { "type": "array" },
        "linkedNoteIds": { "type": "array" }
      },
      "required": ["title", "userId", "subjectId"]
    },
    "Task": {
      "title": "Task",
      "description": "Academic tasks and to-dos.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "status": { "type": "string", "enum": ["todo", "in-progress", "done"] },
        "priority": { "type": "string", "enum": ["low", "medium", "high"] },
        "deadline": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "subjectId": { "type": "string" }
      },
      "required": ["title", "userId", "status"]
    },
    "Event": {
      "title": "Calendar Event",
      "description": "Exams, classes, and study events.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["exam", "class", "review", "other"] },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" },
        "subjectId": { "type": "string" }
      },
      "required": ["title", "userId", "start", "end"]
    },
    "Question": {
      "title": "Question Bank Item",
      "description": "Mock questions for practice.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "options": { "type": "array" },
        "answerIndex": { "type": "number" },
        "explanation": { "type": "string" },
        "subjectId": { "type": "string" },
        "userId": { "type": "string" },
        "difficulty": { "type": "string", "enum": ["easy", "medium", "hard"] },
        "tags": { "type": "array" },
        "source": { "type": "string", "enum": ["manual", "ai"] }
      },
      "required": ["text", "options", "answerIndex", "userId"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "Pomodoro sessions or general focus time.",
      "type": "object",
      "properties": {
        "duration": { "type": "number" },
        "subjectId": { "type": "string" },
        "userId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "ErrorLog": {
      "title": "Error Log Item",
      "description": "Records wrong answers in the question bank for reviewing.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "answeredAt": { "type": "string", "format": "date-time" },
        "wrongOptionIndex": { "type": "number" },
        "correctOptionIndex": { "type": "number" },
        "subjectId": { "type": "string" },
        "context": { "type": "string" },
        "isLearned": { "type": "boolean" }
      },
      "required": ["userId", "questionId", "answeredAt", "wrongOptionIndex", "correctOptionIndex", "subjectId"]
    },
    "Analytics": {
      "title": "Daily Analytics",
      "description": "User performance and study time metrics per day.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "studySeconds": { "type": "number" },
        "questionsAttempted": { "type": "number" },
        "questionsCorrect": { "type": "number" },
        "subjectStats": { "type": "object" }
      },
      "required": ["userId", "date", "studySeconds"]
    },
    "Post": {
      "title": "Community Post",
      "description": "User shared study updates and achievements.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "textContent": { "type": "string" },
        "imageUrl": { "type": "string" },
        "musicLink": { "type": "string" },
        "audioUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["study_update", "achievement", "reflection"] },
        "subjectId": { "type": "string" },
        "studyMinutes": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "likesCount": { "type": "number" },
        "commentsCount": { "type": "number" },
        "isPublic": { "type": "boolean" },
        "likes": { "type": "array" }
      },
      "required": ["userId", "createdAt"]
    },
    "Comment": {
      "title": "Post Comment",
      "description": "User comments on posts.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "content", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "subjects": {
      "schema": "Subject",
      "description": "Academic subjects"
    },
    "flashcards": {
      "schema": "Flashcard",
      "description": "User flashcards"
    },
    "notes": {
      "schema": "Note",
      "description": "User study notes"
    },
    "tasks": {
      "schema": "Task",
      "description": "User tasks"
    },
    "events": {
      "schema": "Event",
      "description": "Calendar events"
    },
    "questions": {
      "schema": "Question",
      "description": "Question bank"
    },
    "studySessions": {
      "schema": "StudySession",
      "description": "Focus history"
    },
    "materials": {
      "schema": "Material",
      "description": "Study materials"
    },
    "studyPlans": {
      "schema": "StudyPlan",
      "description": "User study plans"
    },
    "performanceMetrics": {
      "schema": "PerformanceMetric",
      "description": "User performance data"
    },
    "errors": {
      "schema": "ErrorLog",
      "description": "Caderno de Erros"
    },
    "analytics": {
      "schema": "Analytics",
      "description": "Estatísticas Diárias"
    },
    "simulations": {
      "schema": "Simulation",
      "description": "Simulados realizados"
    },
    "tags": {
      "schema": "GlobalTag",
      "description": "Tags personalizadas"
    },
    "posts": {
      "schema": "Post",
      "description": "Global community feed"
    },
    "comments": {
      "schema": "Comment",
      "description": "Comments on community posts"
    }
  }
}
